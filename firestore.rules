rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Cloud Function চালু হলে users/{uid} এর allow update এ এভাবে বসাবেন:
    //   allow update: if isOwner(uid) && onlyUpdatingFields(['name', 'class']);
    function onlyUpdatingFields(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    // ইউজার প্রোফাইল
    match /users/{uid} {
      allow read: if isSignedIn(); // লিডারবোর্ডে সবার নাম/মার্ক দেখাতে হয়, তাই যেকোনো লগইন করা ইউজার পড়তে পারবে
      allow create: if isOwner(uid);
      // নিজের নাম/ক্লাস বদলাতে পারবে, কিন্তু totalMarks/examsGiven/totalTimeSpentSec সরাসরি বদলাতে পারবে না —
      // ⚠️ এই মুহূর্তে user-service.js এর updateUserStatsAfterExam ক্লায়েন্ট থেকে সরাসরি এই ফিল্ডগুলো বদলায়,
      // তাই আপাতত exam-submission flow কাজ করানোর জন্য results-ভিত্তিক write নিচে আলাদাভাবে অনুমোদিত।
      // প্রোডাকশনে এটা Cloud Function (results onCreate trigger) দিয়ে সার্ভার-সাইডে করা উচিত এবং
      // তখন নিচের allow update লাইন থেকে totalMarks/examsGiven/totalTimeSpentSec বাদ দিয়ে দিতে হবে।
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // বিষয় লিস্ট — শুধু অ্যাডমিন কনসোল/Admin SDK থেকে লেখা হবে
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // এক্সাম মেটাডাটা — শুধু অ্যাডমিন লিখবে
    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // প্রশ্ন — ⚠️ correctAnswer ফিল্ড এই মুহূর্তে ক্লায়েন্টে read হয়ে যাচ্ছে (question-service.js),
      // যা দিয়ে ব্রাউজার DevTools থেকে উত্তর দেখে ফেলা সম্ভব। Firestore rules দিয়ে ফিল্ড-লেভেল hide করা যায় না।
      // প্রোডাকশনে সমাধান: correctAnswer আলাদা কালেকশনে রাখুন (শুধু Cloud Function পড়তে পারবে) এবং
      // exam submission একটা callable Cloud Function দিয়ে সার্ভার-সাইডে score করুন।
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // রেজাল্ট — প্রতিটা ইউজার শুধু নিজেরটা পড়তে/তৈরি করতে পারবে, বদলাতে/মুছতে পারবে না
    match /results/{resultId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ক্যাশড লিডারবোর্ড (ভবিষ্যতে Cloud Function দিয়ে আপডেট হবে) — এখন কোডে ব্যবহৃত হচ্ছে না,
    // leaderboard-service.js আপাতত সরাসরি users কালেকশন থেকে পড়ছে
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
